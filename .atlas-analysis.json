  "keyFeatures": [
    "HHblits for fast iterative sequence database searching",
    "HHsearch for sensitive protein homology detection",
    "HHalign for pairwise HMM-HMM alignment",
    "Profile HMM construction with HHmake",
    "SIMD optimizations (SSE2, AVX2) for performance",
    "MPI and OpenMP support for parallel processing",
    "Multiple sequence alignment filtering and manipulation",
    "Support for major protein databases (Uniclust30, BFD, Pfam, PDB70)"
